# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Vagrantfile for tessera E2E test boxes.
#
# Boxes:
#   default     — Astra-proxy box (Ubuntu 22.04, full toolchain). Used
#                 for stage-1/stage-2 smoke fixtures and PKCS#12 flows.
#
# Bring up:
#   vagrant up default

Vagrant.configure("2") do |config|
  config.vm.box = "bento/ubuntu-22.04"
  config.vm.box_version = ">= 202307.0.0"

  # ----------------------------------------------------------------------
  # Default box — full-stack provisioning (build toolchain + deps).
  # ----------------------------------------------------------------------
  config.vm.define "default", primary: true do |box|
    box.vm.hostname = "tessera-test"
    box.vm.network "private_network", type: "dhcp"

    box.vm.synced_folder "..", "/srv/source",
      type: "rsync",
      rsync__exclude: ["target/", ".git/", ".idea/"]

    box.vm.provider "virtualbox" do |vb|
      vb.memory = 2048
      vb.cpus = 2
      vb.customize ["modifyvm", :id, "--usb", "on"]
      vb.customize ["modifyvm", :id, "--usbehci", "on"]
    end

    box.vm.provision "shell", path: "provision.sh"
  end
end

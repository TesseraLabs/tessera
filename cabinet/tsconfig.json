{
  // `exactOptionalPropertyTypes` is deliberately OFF: the WASM/serve JSON
  // contracts in `src/types.ts` use plain `field?: T` optionals, and the app
  // routinely builds those objects from other optional (`T | undefined`)
  // values (form fields, parsed CSR data). That is completely standard JS
  // behaviour — assigning `undefined` to an optional field — but
  // `exactOptionalPropertyTypes` treats it as a type error unless every
  // optional is redeclared as `T | undefined`, which would just be ceremony
  // here for no real safety gain (`noUncheckedIndexedAccess` below already
  // covers the array/index cases this flag doesn't).
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": false,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "types": ["node"]
  },
  "include": ["src"]
}

#!/bin/sh
# Block commits to main during working hours (Mon-Fri 08:00-18:59 local time).
# Rationale: main history should only move outside business hours.
# Emergency override: git commit --no-verify

branch=$(git symbolic-ref --quiet --short HEAD) || exit 0 # detached HEAD (rebase/bisect): allow
[ "$branch" = "main" ] || exit 0

dow=$(date +%u)  # 1=Mon .. 7=Sun
hour=$(date +%H)

if [ "$dow" -le 5 ] && [ "$hour" -ge 8 ] && [ "$hour" -lt 19 ]; then
    echo "pre-commit: commits to 'main' are blocked on weekdays 08:00-19:00." >&2
    echo "Use a feature branch, or commit after 19:00 (--no-verify to override)." >&2
    exit 1
fi
exit 0

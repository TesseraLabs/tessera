# OpenSSL config — leaf with MAX_INTEGRITY level=3, empty categories.
# Used for tests that need a higher cert level than current runtime
# clearance to confirm intersection-with-runtime semantics.
# DER: SEQUENCE { INTEGER 3, BIT STRING ''B } = 30 06 02 01 03 03 01 00
#  inner = INTEGER 3 (02 01 03, 3 octets) + BIT STRING '' (03 01 00, 3 octets) = 6 octets
[ req ]
default_bits        = 2048
default_md          = sha256
prompt              = no
distinguished_name  = dn
req_extensions      = leaf_ext

[ dn ]
CN = mac-l3
O  = pam_certauth-test
C  = RU

[ leaf_ext ]
basicConstraints       = critical, CA:FALSE
keyUsage               = critical, digitalSignature, keyEncipherment
extendedKeyUsage       = clientAuth, emailProtection
subjectKeyIdentifier   = hash
1.3.6.1.4.1.99999.1.2 = ASN1:UTF8String:testuser
2.25.273824307386008814506455310913083078403 = critical,DER:30:06:02:01:03:03:01:00

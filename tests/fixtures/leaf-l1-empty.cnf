# OpenSSL config — leaf with MAX_INTEGRITY level=1, empty categories.
# DER payload for SEQUENCE { INTEGER 1, BIT STRING ''B }:
#   30 06 02 01 01 03 01 00
#   ^^ ^^                       SEQUENCE, content length = 6 octets
#      ^^ 02 01 01              INTEGER 1                     (3 octets)
#                03 01 00       BIT STRING (0 unused bits, '') (3 octets)
[ req ]
default_bits        = 2048
default_md          = sha256
prompt              = no
distinguished_name  = dn
req_extensions      = leaf_ext

[ dn ]
CN = mac-l1-empty
O  = pam_certauth-test
C  = RU

[ leaf_ext ]
basicConstraints       = critical, CA:FALSE
keyUsage               = critical, digitalSignature, keyEncipherment
extendedKeyUsage       = clientAuth, emailProtection
subjectKeyIdentifier   = hash
1.3.6.1.4.1.99999.1.2 = ASN1:UTF8String:testuser
2.25.273824307386008814506455310913083078403 = critical,DER:30:06:02:01:01:03:01:00

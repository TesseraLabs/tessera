# OpenSSL config — leaf with pam_cert_allowed_roles = [oper].
#
# The login requests `+serv`; this cert lists only `oper`, so coverage MUST
# fail (role not in allowed_roles) → role_deny reason=not_covered.
#
# OID 2.25.185305973969816596290730578528098241367 (ALLOWED_ROLES_OID, see
# crates/tessera_core/src/x509/oids.rs — do NOT change).
#
# DER payload for SEQUENCE { UTF8String "oper" }:
#   30 06 0c 04 6f 70 65 72
#   ^^ ^^                      SEQUENCE, content length = 6 octets
#      ^^ 0c 04 6f 70 65 72    UTF8String "oper"            (6 octets)
[ req ]
default_bits        = 2048
default_md          = sha256
prompt              = no
distinguished_name  = dn
req_extensions      = leaf_ext

[ dn ]
CN = role-oper
O  = tessera-test
C  = RU

[ leaf_ext ]
basicConstraints       = critical, CA:FALSE
keyUsage               = critical, digitalSignature, keyEncipherment
extendedKeyUsage       = clientAuth, emailProtection
subjectKeyIdentifier   = hash
# pam_cert_host_binding = ["*"]  (wildcard — authorises any host, test leaf)
2.25.183976554325829274683049824615098 = DER:30:03:0c:01:2a
2.25.215438916728501023845629178354627 = DER:30:08:0c:06:69:76:61:6e:6f:76
# pam_cert_allowed_roles = [oper]  (non-critical)
2.25.185305973969816596290730578528098241367 = DER:30:06:0c:04:6f:70:65:72

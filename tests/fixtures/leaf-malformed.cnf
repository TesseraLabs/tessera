# OpenSSL config — leaf with MAX_INTEGRITY containing malformed DER.
# Used to test parser robustness: malformed extension must cause
# rejection in required mode and the parse-failed audit event.
# Payload: raw garbage bytes, not a valid DER SEQUENCE.
[ req ]
default_bits        = 2048
default_md          = sha256
prompt              = no
distinguished_name  = dn
req_extensions      = leaf_ext

[ dn ]
CN = mac-malformed
O  = pam_certauth-test
C  = RU

[ leaf_ext ]
basicConstraints       = critical, CA:FALSE
keyUsage               = critical, digitalSignature, keyEncipherment
extendedKeyUsage       = clientAuth, emailProtection
subjectKeyIdentifier   = hash
1.3.6.1.4.1.99999.1.2 = ASN1:UTF8String:testuser
2.25.273824307386008814506455310913083078403 = critical,DER:DE:AD:BE:EF

# OpenSSL config — leaf with MAX_INTEGRITY level=2 categories={0}
# Used by setup-mac-fixtures.sh to generate test leaves signed by the
# CA in tests/fixtures/ca.{key,crt}.pem.
#
# DER payload for SEQUENCE { INTEGER 2, BIT STRING '0...01'B }:
#   30 07 02 01 02 03 02 00 01
#   ^^ ^^                       SEQUENCE, content length = 7 octets
#      ^^ 02 01 02              INTEGER 2                     (3 octets)
#                03 02 00 01    BIT STRING (0 unused bits, 0x01) (4 octets)
[ req ]
default_bits        = 2048
default_md          = sha256
prompt              = no
distinguished_name  = dn
req_extensions      = leaf_ext

[ dn ]
CN = mac-l2-c01
O  = pam_certauth-test
C  = RU

[ leaf_ext ]
basicConstraints       = critical, CA:FALSE
keyUsage               = critical, digitalSignature, keyEncipherment
extendedKeyUsage       = clientAuth, emailProtection
subjectKeyIdentifier   = hash
# pam_cert_user_binding (placeholder OID for tests)
1.3.6.1.4.1.99999.1.2 = ASN1:UTF8String:testuser
# MAX_INTEGRITY (Astra МКЦ): level=2, categories={0}
2.25.273824307386008814506455310913083078403 = critical,DER:30:07:02:01:02:03:02:00:01
